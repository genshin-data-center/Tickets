<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>لوحة التذاكر</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #0b0d0f;
    --surface:   #111418;
    --surface2:  #181c22;
    --border:    #1e2530;
    --accent:    #5865F2;
    --accent2:   #4752c4;
    --green:     #3ba55d;
    --red:       #ed4245;
    --text:      #e3e5e8;
    --muted:     #72767d;
    --tag-bg:    #1a1f2e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Sans Arabic', sans-serif;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .layout { display: flex; min-height: 100vh; }
  .sidebar {
    width: 240px; flex-shrink: 0;
    background: var(--surface);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    padding: 24px 0;
    position: sticky; top: 0; height: 100vh;
  }
  .sidebar-logo {
    padding: 0 20px 24px;
    font-size: 18px; font-weight: 600; letter-spacing: -0.3px;
    display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid var(--border);
  }
  .logo-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); }
  .sidebar-nav { padding: 16px 12px; flex: 1; }
  .nav-label { font-size: 10px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; padding: 0 8px; margin-bottom: 6px; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 8px;
    color: var(--muted); font-size: 14px; text-decoration: none;
    transition: all 0.15s;
  }
  .nav-item:hover, .nav-item.active { background: var(--surface2); color: var(--text); }
  .nav-item.active { color: var(--accent); }
  .sidebar-user {
    padding: 16px 20px;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .user-avatar { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
  .user-name { font-size: 13px; font-weight: 500; }
  .logout-btn {
    margin-right: auto; background: none; border: none;
    color: var(--muted); cursor: pointer; font-size: 12px;
    transition: color 0.15s;
  }
  .logout-btn:hover { color: var(--red); }

  /* ── Main content ── */
  .main { flex: 1; padding: 40px 48px; overflow-y: auto; }
  .page-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px;
  }
  .page-title { font-size: 26px; font-weight: 600; letter-spacing: -0.5px; }
  .page-subtitle { font-size: 13px; color: var(--muted); margin-top: 4px; }

  /* ── Stats row ── */
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 20px 24px;
  }
  .stat-value { font-size: 28px; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
  .stat-label { font-size: 12px; color: var(--muted); margin-top: 4px; }

  /* ── Filters ── */
  .filters {
    display: flex; gap: 12px; margin-bottom: 20px;
    flex-wrap: wrap; align-items: center;
  }
  .search-box {
    flex: 1; min-width: 200px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 14px;
    color: var(--text); font-family: inherit; font-size: 14px;
    outline: none; transition: border-color 0.15s;
  }
  .search-box:focus { border-color: var(--accent); }
  .filter-select {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 14px;
    color: var(--text); font-family: inherit; font-size: 14px;
    outline: none; cursor: pointer;
  }
  .filter-btn {
    background: var(--accent); border: none; border-radius: 8px;
    padding: 9px 18px; color: white; font-family: inherit;
    font-size: 14px; cursor: pointer; transition: background 0.15s;
  }
  .filter-btn:hover { background: var(--accent2); }

  /* ── Table ── */
  .table-wrap {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
  }
  table { width: 100%; border-collapse: collapse; }
  thead tr { border-bottom: 1px solid var(--border); }
  th {
    padding: 12px 18px; text-align: right;
    font-size: 11px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.8px;
  }
  td { padding: 14px 18px; font-size: 14px; border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tbody tr { transition: background 0.1s; cursor: pointer; }
  tbody tr:hover { background: var(--surface2); }

  .ticket-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; color: var(--accent); font-weight: 600;
  }
  .user-cell { display: flex; align-items: center; gap: 10px; }
  .user-cell img { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; }
  .category-tag {
    display: inline-block; padding: 3px 10px; border-radius: 20px;
    font-size: 12px; background: var(--tag-bg); border: 1px solid var(--border);
  }
  .date-cell { font-size: 12px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

  /* ── Pagination ── */
  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; margin-top: 28px;
  }
  .page-btn {
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text); border-radius: 8px; padding: 7px 14px;
    font-size: 13px; text-decoration: none; transition: all 0.15s;
    font-family: inherit;
  }
  .page-btn:hover { border-color: var(--accent); color: var(--accent); }
  .page-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
  .page-btn.disabled { opacity: 0.4; pointer-events: none; }

  /* ── Empty state ── */
  .empty {
    text-align: center; padding: 60px 24px;
    color: var(--muted); font-size: 15px;
  }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
</style>
</head>
<body>
<div class="layout">

  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-dot"></div>
      لوحة التذاكر
    </div>
    <div class="sidebar-nav">
      <div class="nav-label">القائمة</div>
      <a href="/" class="nav-item active">
        <span>🎫</span> التذاكر
      </a>
    </div>
    <div class="sidebar-user">
      <img src="<%= user.avatar %>" class="user-avatar" alt="">
      <span class="user-name"><%= user.username %></span>
      <button class="logout-btn" onclick="location.href='/logout'">خروج</button>
    </div>
  </nav>

  <!-- Main -->
  <main class="main">
    <div class="page-header">
      <div>
        <div class="page-title">سجل التذاكر</div>
        <div class="page-subtitle"><%= total %> تذكرة مسجلة</div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats">
      <div class="stat-card">
        <div class="stat-value"><%= total %></div>
        <div class="stat-label">إجمالي التذاكر</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= categories.length %></div>
        <div class="stat-label">الأقسام</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= page %> / <%= pages %></div>
        <div class="stat-label">الصفحة الحالية</div>
      </div>
    </div>

    <!-- Filters -->
    <form method="GET" action="/">
      <div class="filters">
        <input class="search-box" type="text" name="q" placeholder="ابحث باسم المستخدم أو رقم التذكرة..." value="<%= search %>">
        <select class="filter-select" name="cat">
          <option value="">كل الأقسام</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
        <button class="filter-btn" type="submit">بحث</button>
        <% if (search || category) { %>
          <a class="filter-btn" href="/" style="background:var(--surface2);text-decoration:none;">مسح</a>
        <% } %>
      </div>
    </form>

    <!-- Table -->
    <div class="table-wrap">
      <% if (tickets.length === 0) { %>
        <div class="empty">
          <div class="empty-icon">📭</div>
          لا توجد تذاكر مسجلة
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>فاتح التذكرة</th>
            <th>القسم</th>
            <th>استلمها</th>
            <th>أغلقها</th>
            <th>تاريخ الإغلاق</th>
          </tr>
        </thead>
        <tbody>
          <% tickets.forEach(t => { %>
          <tr onclick="location.href='/ticket/<%= t.id %>'">
            <td><span class="ticket-num">#<%= t.ticket_id %></span></td>
            <td>
              <div class="user-cell">
                <% if (t.opened_by_avatar) { %>
                  <img src="<%= t.opened_by_avatar %>" alt="" onerror="this.style.display='none'">
                <% } %>
                <%= t.opened_by_name || 'غير معروف' %>
              </div>
            </td>
            <td><span class="category-tag"><%= t.category || '—' %></span></td>
            <td><%= t.claimed_by_name || '—' %></td>
            <td><%= t.closed_by_name || '—' %></td>
            <td class="date-cell"><%= t.closed_at ? new Date(t.closed_at).toLocaleDateString('ar-SA') : '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Pagination -->
    <% if (pages > 1) { %>
    <div class="pagination">
      <a href="?page=<%= Math.max(1, page-1) %>&q=<%= search %>&cat=<%= category %>"
         class="page-btn <%= page === 1 ? 'disabled' : '' %>">‹ السابق</a>
      <% for (let i = Math.max(1, page-2); i <= Math.min(pages, page+2); i++) { %>
        <a href="?page=<%= i %>&q=<%= search %>&cat=<%= category %>"
           class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <a href="?page=<%= Math.min(pages, page+1) %>&q=<%= search %>&cat=<%= category %>"
         class="page-btn <%= page === pages ? 'disabled' : '' %>">التالي ›</a>
    </div>
    <% } %>

  </main>
</div>
</body>
</html>
